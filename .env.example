# ── LLM Provider ──────────────────────────────────────────────────────────
# Escolha o provider: openai (padrão) ou anthropic
LLM_PROVIDER=openai

# OpenAI (necessário quando LLM_PROVIDER=openai)
OPENAI_API_KEY=sk-...

# Anthropic Claude (necessário quando LLM_PROVIDER=anthropic)
# ANTHROPIC_API_KEY=sk-ant-...

# ── Observabilidade — LangSmith ───────────────────────────────────────────
# Obtenha em: https://smith.langchain.com
LANGCHAIN_TRACING_V2=true
LANGSMITH_API_KEY=lsv2_...
LANGSMITH_PROJECT=rag-chatbot

# ── Langfuse (alternativa open-source self-hostable) ──────────────────────
# LANGFUSE_SECRET_KEY=sk-lf-...
# LANGFUSE_PUBLIC_KEY=pk-lf-...
# LANGFUSE_HOST=https://cloud.langfuse.com

# ── Infra (apenas necessário com docker compose) ──────────────────────────
# Quando rodar via `docker compose up`, esses URLs apontam para os services
# definidos no docker-compose.yml. Para uso local sem Docker, deixe vazio
# (o pipeline cai no QdrantClient(":memory:") e ignora os outros).
QDRANT_URL=http://qdrant:6333
POSTGRES_URL=postgresql://rag:rag@postgres:5432/rag
REDIS_URL=redis://redis:6379/0
