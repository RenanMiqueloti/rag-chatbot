# ── LLM Provider ──────────────────────────────────────────────────────────
# Escolha o provider: openai (padrão), anthropic ou groq
LLM_PROVIDER=openai

# OpenAI (necessário quando LLM_PROVIDER=openai)
OPENAI_API_KEY=sk-...

# Anthropic Claude (necessário quando LLM_PROVIDER=anthropic)
# ANTHROPIC_API_KEY=sk-ant-...

# Groq (necessário quando LLM_PROVIDER=groq) — free tier, rate-limited
# GROQ_API_KEY=gsk_...

# ── Observabilidade — LangSmith ───────────────────────────────────────────
# Obtenha em: https://smith.langchain.com
# Mantenha em ``false`` se não tiver chave — caso contrário cada call emite warning.
LANGCHAIN_TRACING_V2=false
# LANGSMITH_API_KEY=lsv2_...
LANGSMITH_PROJECT=rag-chatbot

# ── Langfuse (alternativa open-source self-hostable) ──────────────────────
# LANGFUSE_SECRET_KEY=sk-lf-...
# LANGFUSE_PUBLIC_KEY=pk-lf-...
# LANGFUSE_HOST=https://cloud.langfuse.com

# ── Infra (Qdrant) ────────────────────────────────────────────────────────
# QDRANT_URL aponta pro servidor Qdrant (compose, cluster, etc).
# Vazio = fallback pra in-memory (sem persistência).
# QDRANT_API_KEY: usado apenas em Qdrant Cloud / instância protegida.
QDRANT_URL=http://qdrant:6333
# QDRANT_API_KEY=
