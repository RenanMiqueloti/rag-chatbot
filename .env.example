# ── LLM Provider ──────────────────────────────────────────────────────────
# Escolha o provider: openai (padrão), anthropic ou groq
LLM_PROVIDER=openai

# OpenAI (necessário quando LLM_PROVIDER=openai)
OPENAI_API_KEY=sk-...

# Anthropic Claude (necessário quando LLM_PROVIDER=anthropic)
# ANTHROPIC_API_KEY=sk-ant-...

# Groq (necessário quando LLM_PROVIDER=groq) — free tier, rate-limited
# GROQ_API_KEY=gsk_...

# ── Observabilidade — LangSmith ───────────────────────────────────────────
# Obtenha em: https://smith.langchain.com
# Mantenha em ``false`` se não tiver chave — caso contrário cada call emite warning.
LANGCHAIN_TRACING_V2=false
# LANGSMITH_API_KEY=lsv2_...
LANGSMITH_PROJECT=rag-chatbot

# ── Langfuse (alternativa open-source self-hostable) ──────────────────────
# LANGFUSE_SECRET_KEY=sk-lf-...
# LANGFUSE_PUBLIC_KEY=pk-lf-...
# LANGFUSE_HOST=https://cloud.langfuse.com

# ── Modelos do pipeline RAG (overrides opcionais) ─────────────────────────
# Multilingual por padrão (corpus PT-BR). Comente as linhas pra usar defaults.
# EMBEDDING_MODEL aceita qualquer sentence-transformers; modelos E5 ganham
# wrapper automático com prefixos 'query:' / 'passage:'.
# EMBEDDING_MODEL=intfloat/multilingual-e5-small
# RERANKER_MODEL=ms-marco-MiniLM-L-12-v2

# ── Rate limiting (FastAPI / api.py) ──────────────────────────────────────
# Limites por IP — slowapi in-memory. Vazio/0 desativa.
RATE_LIMIT_PER_MINUTE=10
RATE_LIMIT_PER_HOUR=100
# Circuit breaker global de requests/dia (reset em meia-noite UTC).
# 0 desativa. Útil pra proteger free tier do provider quando muitos IPs
# distintos consomem em paralelo. Default 80 alinha com Groq free
# (100k tokens/dia ÷ ~1.2k tokens/query); ajuste se mudar de provider.
DAILY_REQUEST_CAP=80
# Tamanho máximo da query enviada (chars). Excedente retorna 422.
MAX_QUERY_CHARS=2000

# ── Infra (Qdrant) ────────────────────────────────────────────────────────
# QDRANT_URL aponta pro servidor Qdrant (compose, cluster, etc).
# Vazio = fallback pra in-memory (sem persistência).
# QDRANT_API_KEY: usado apenas em Qdrant Cloud / instância protegida.
QDRANT_URL=http://qdrant:6333
# QDRANT_API_KEY=
